# ──────────────────────────────────────────────────────────────────────────────
# Telegram Drive Monitor — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────

# Bot token obtained from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated list of Telegram user IDs that are allowed to use the bot.
# Get your ID by messaging @userinfobot or @getidsbot on Telegram.
ADMIN_USER_IDS=123456789,987654321

# ── Google Drive ───────────────────────────────────────────────────────────────

# ID of the Google Drive folder to monitor.
# Extract from the URL: https://drive.google.com/drive/folders/<FOLDER_ID>
DRIVE_FOLDER_ID=your_folder_id_here

# Path to the Service Account credentials JSON file downloaded from Google Cloud.
GOOGLE_CREDENTIALS_FILE=credentials.json

# ── Monitoring ─────────────────────────────────────────────────────────────────

# How often (in seconds) to poll the Drive folder for changes.
# Minimum: 60, Maximum: 3600. Default: 300 (5 minutes).
POLL_INTERVAL=300

# ── Display ────────────────────────────────────────────────────────────────────

# Number of files shown per page in the /list command (1–50). Default: 10.
PAGE_SIZE=10

# ── Database ───────────────────────────────────────────────────────────────────

# Path to the SQLite database file. Default: drive_monitor.db
DATABASE_PATH=drive_monitor.db

# ── Logging ────────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR. Default: INFO.
LOG_LEVEL=INFO

# ── Advanced ───────────────────────────────────────────────────────────────────

# HTTP request timeout in seconds for external API calls. Default: 30.
REQUEST_TIMEOUT=30

# YouTube Data API v3 key (required for /extract_youtube).
YOUTUBE_API_KEY=
